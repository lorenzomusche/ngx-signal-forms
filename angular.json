{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "ngx-signal-forms": {
            "projectType": "library",
            "root": "projects/ngx-signal-forms",
            "sourceRoot": "projects/ngx-signal-forms/src",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:ng-packagr",
                    "options": {
                        "project": "projects/ngx-signal-forms/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/ngx-signal-forms/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                }
            }
        },
        "demo": {
            "projectType": "application",
            "root": "projects/demo",
            "sourceRoot": "projects/demo/src",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "outputPath": "dist/demo",
                        "index": "projects/demo/src/index.html",
                        "browser": "projects/demo/src/main.ts",
                        "tsConfig": "projects/demo/tsconfig.app.json",
                        "styles": [
                            "projects/demo/src/styles.scss"
                        ],
                        "stylePreprocessorOptions": {
                            "includePaths": [
                                "projects/ngx-signal-forms/src/styles"
                            ]
                        }
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "1MB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "demo:build:production"
                        },
                        "development": {
                            "buildTarget": "demo:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                }
            }
        }
    }
}