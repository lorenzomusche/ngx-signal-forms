{
  // ─── GitHub Copilot ───────────────────────────────────────────────────────────

  // Le istruzioni custom sono nei file dedicati in .github/copilot/
  // (nuovo sistema - vedi .github/copilot/*.md)
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // ─── TypeScript ───────────────────────────────────────────────────────────────

  // Usa il TypeScript del progetto (non quello bundled di VS Code)
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Strict checks visibili nell'editor
  "typescript.preferences.strictNullChecks": true,
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Inlay hints — tipi inferiti visibili inline senza hover
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,

  // ─── Angular Language Service ─────────────────────────────────────────────────

  "angular.experimental-ivy": true,

  // ─── Editor ───────────────────────────────────────────────────────────────────

  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.occurrencesHighlight": "multiFile",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // ─── File Associations ────────────────────────────────────────────────────────

  "files.associations": {
    "*.ts": "typescript",
    "*.html": "html"
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.angular": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.angular": true,
    "**/coverage": true
  }
}
