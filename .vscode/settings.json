{
  // ─── GitHub Copilot ───────────────────────────────────────────────────────────

  // Abilita la lettura automatica di .github/copilot-instructions.md
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // Collega copilot-instructions.md anche alle review manuali (Cmd+I → Review)
  "github.copilot.chat.reviewSelection.instructions": [
    { "file": ".github/copilot-instructions.md" }
  ],

  // Collega copilot-instructions.md alla generazione di test
  "github.copilot.chat.testGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" }
  ],

  // Collega copilot-instructions.md alle commit message suggestions
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" }
  ],

  // ─── TypeScript ───────────────────────────────────────────────────────────────

  // Usa il TypeScript del progetto (non quello bundled di VS Code)
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Strict checks visibili nell'editor
  "typescript.preferences.strictNullChecks": true,
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Inlay hints — fondamentali per vedere i tipi inferiti in tempo reale
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,

  // ─── Angular Language Service ─────────────────────────────────────────────────

  "angular.experimental-ivy": true,

  // ─── Editor ───────────────────────────────────────────────────────────────────

  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Evidenzia i riferimenti al simbolo sotto cursore
  "editor.occurrencesHighlight": "multiFile",

  // Bracket pair colorization
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // ─── File Associations ────────────────────────────────────────────────────────

  "files.associations": {
    "*.ts": "typescript",
    "*.html": "html"
  },

  // Escludi dalla ricerca e dall'explorer le cartelle di build/cache
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.angular": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.angular": true,
    "**/coverage": true
  }
}
